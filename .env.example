# DTL Nightly — Environment Variables
# Copy this to .env.local and fill in your values

# MapTiler (basemap tiles)
NEXT_PUBLIC_MAPTILER_KEY=

# Supabase (database + auth)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Crisis Dashboard
CRISIS_PIN=1234

# Ticketmaster Discovery API v2 (event ingestion)
TICKETMASTER_API_KEY=

# Instagram Webhook (optional)
META_WEBHOOK_VERIFY_TOKEN=

# Cron Job Authentication (secures /api/cron/* endpoints)
CRON_SECRET=

# Firebase Service Account (FCM v1 API — geofence sync)
# Paste the entire JSON content of your service account key file, on one line
GOOGLE_SERVICE_ACCOUNT_KEY=
